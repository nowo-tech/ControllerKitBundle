# APP_ENV: Symfony environment (dev/test/prod). In demos it is usually `dev`.
APP_ENV=dev

# APP_DEBUG: Enable/disable detailed debug output (usually `1` in dev).
APP_DEBUG=1

# APP_SECRET: Secret used for signing/tokens. Use a local-only value in demos.
APP_SECRET=CHANGE_ME_LOCAL_SECRET

# PORT: Host port mapped to HTTP :80 inside the FrankenPHP container (symfony7 demo default: 8010).
PORT=8010

# DEFAULT_URI: Base URL for generating URLs in CLI (must match PORT for local HTTP checks).
DEFAULT_URI=http://localhost:8010
