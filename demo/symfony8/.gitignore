# ------------------------------------------------------------------------------
# Local environment (do not version secrets)
# ------------------------------------------------------------------------------
# Copy from .env.example via `make up` / `make install`. Do not commit .env,
# .env.dev, or machine-specific locals (REQ-DEMO-003 / REQ-ENV-001).
/.env
/.env.dev
/.env.local
/.env.local.php
/.env.*.local

# ------------------------------------------------------------------------------
# Dependencies & build artifacts
# ------------------------------------------------------------------------------
/vendor/
/node_modules/
/.pnpm-store/
/public/build/
/public/bundles/
/dist/

# ------------------------------------------------------------------------------
# Caches, logs, and runtime
# ------------------------------------------------------------------------------
/var/
*.log
/.phpunit.cache/
/phpunit.xml
/.php-cs-fixer.cache

# ------------------------------------------------------------------------------
# Symfony secrets
# ------------------------------------------------------------------------------
/config/secrets/prod/prod.decrypt.private.php

# ------------------------------------------------------------------------------
# Archives / compressed (REQ-GITIGNORE-001)
# ------------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
